{
  "manifest_version": 3,
  "name": "ByteShield",
  "version": "1.6",
  "description": "Real-Time ML Phishing Detector",
  "permissions": [
    "activeTab",
    "tabs",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "*.wasm",
        "*.mjs"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}